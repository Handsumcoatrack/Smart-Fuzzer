    parser.add_argument('-xs', '--exclude-strings',
                        help='Comma-separated strings to exclude')
    parser.add_argument('-xr', '--exclude-regex',
                        help='Comma-separated regex patterns to exclude')
    
    # Baseline options
    parser.add_argument('--length-threshold', type=int, default=50,
                        help='Byte difference threshold for anomaly detection (default: 50)')
    parser.add_argument('--similarity-threshold', type=float, default=0.9,
                        help='Content similarity threshold 0-1 (default: 0.9)')
    
    args = parser.parse_args()
    
    # Build additional wordlists list
    additional_wordlists = []
    if args.wordlist2:
        additional_wordlists.append(args.wordlist2)
    if args.wordlist3:
        additional_wordlists.append(args.wordlist3)
    if args.wordlist4:
        additional_wordlists.append(args.wordlist4)
    
    # Parse comma-separated arguments
    match_strings = [s.strip() for s in args.match_strings.split(',')] if args.match_strings else []
    match_regex = [s.strip() for s in args.match_regex.split(',')] if args.match_regex else []
    exclude_strings = [s.strip() for s in args.exclude_strings.split(',')] if args.exclude_strings else []
    exclude_regex = [s.strip() for s in args.exclude_regex.split(',')] if args.exclude_regex else []
    
    fuzzer = ThreadedFuzzer(
        target_url=args.url,
        wordlist_path=args.wordlist,
        threads=args.threads,
        delay=args.delay,
        retries=args.retries,
        match_strings=match_strings,
        match_regex=match_regex,
        exclude_strings=exclude_strings,
        exclude_regex=exclude_regex,
        length_threshold=args.length_threshold,
        similarity_threshold=args.similarity_threshold,
        method=args.method,
        headers=parse_headers(args.header),
        cookies=parse_cookies(args.cookies),
        post_data=args.data,
        additional_wordlists=additional_wordlists
    )
    
    fuzzer.run()
